# hyprplane — example config (additive / opt-in).
#
# 1. Build the plugin (see README), then point this at the built .so.
# 2. Source this file at the END of your ~/.config/hypr/hyprland.conf:
#       source = ~/.config/hypr/canvas.conf
# 3. Reload Hyprland (or relog).
#
# To disable everything: remove the `source =` line above and relog.

# Load the plugin at startup. Adjust the path to where you built it.
plugin = /home/YOURUSER/hyprplane/build/hyprplane.so

# Toggle canvas mode on the focused workspace(s) — affects all monitors at once.
bind = SUPER, grave, canvas:toggle

# Optional keyboard panning while in canvas mode (mouse drag also pans).
bind = SUPER CTRL, K, canvas:pan, 0 -200
bind = SUPER CTRL, J, canvas:pan, 0 200

# In canvas mode you can also pan by holding MIDDLE-mouse (or CTRL + left) and dragging.

# Full-display overview: zoom OUT (crisp monitor downscale) to fit all windows, toggle
# back to native. This is the companion script scripts/canvas-overview (point the path
# at wherever you cloned the repo). Pick a key that doesn't clash with your setup.
bind = SUPER CTRL, O, exec, /home/YOURUSER/hyprplane/scripts/canvas-overview

# In canvas mode, SUPER+1..0 focus the Nth-LARGEST window (and centre it in view). Outside
# canvas mode they fall back to normal `workspace N` switching, so day-to-day use is
# unchanged. (code:10..19 are the digit row 1,2,...,9,0 — used so it works regardless of
# keyboard layout and overrides the stock workspace binds. Drop the `unbind` lines if your
# config doesn't already bind these.)
unbind = SUPER, code:10
unbind = SUPER, code:11
unbind = SUPER, code:12
unbind = SUPER, code:13
unbind = SUPER, code:14
unbind = SUPER, code:15
unbind = SUPER, code:16
unbind = SUPER, code:17
unbind = SUPER, code:18
unbind = SUPER, code:19
bind = SUPER, code:10, canvas:jump, 1
bind = SUPER, code:11, canvas:jump, 2
bind = SUPER, code:12, canvas:jump, 3
bind = SUPER, code:13, canvas:jump, 4
bind = SUPER, code:14, canvas:jump, 5
bind = SUPER, code:15, canvas:jump, 6
bind = SUPER, code:16, canvas:jump, 7
bind = SUPER, code:17, canvas:jump, 8
bind = SUPER, code:18, canvas:jump, 9
bind = SUPER, code:19, canvas:jump, 10

# Tunables (all optional — these are the defaults). Change + `hyprctl reload` to apply.
plugin {
    hyprplane {
        minimap = 1            # 0 = disable the grab-pan minimap
        minimap_size = 0.28    # panel width as a fraction of the monitor (0.1–0.6)
        minimap_position = 0   # 0 bottom-right, 1 bottom-left, 2 top-right, 3 top-left
        fade_speed = 0.18      # minimap fade easing (higher = snappier)
        grab_button = 2        # pan trigger: 0 middle, 1 ctrl+left, 2 both
        jump_order = 0         # SUPER+number order: 0 largest, 1 left-to-right, 2 oldest
    }
}
